# Copy this file to .env and fill in real values
# DO NOT commit .env — it is gitignored

# --- Runtime ---
# LOBSTER_MODE=tool              # Force tool-mode output (JSON envelope)
# LOBSTER_SHELL=/bin/bash        # Override shell used for exec commands

# --- State & Cache ---
# LOBSTER_STATE_DIR=             # Override state storage directory (default: .lobster/)
# LOBSTER_CACHE_DIR=             # Override LLM response cache directory

# --- LLM Provider ---
# LOBSTER_LLM_PROVIDER=          # LLM provider: pi | http | (auto-detect from env)
# LOBSTER_LLM_MODEL=             # Model name override for llm.invoke / llm.task
# LOBSTER_LLM_SCHEMA_VERSION=    # Schema version for LLM task output
# LOBSTER_LLM_VALIDATION_RETRIES= # Number of retries on LLM validation failure
# LOBSTER_LLM_FORCE_REFRESH=     # Skip cache and force fresh LLM call

# --- LLM Adapter (generic HTTP) ---
# LOBSTER_LLM_ADAPTER_URL=       # HTTP adapter endpoint URL
# LOBSTER_LLM_ADAPTER_TOKEN=     # Bearer token for HTTP adapter

# --- LLM Adapter (Pi) ---
# LOBSTER_PI_LLM_ADAPTER_URL=    # Pi-specific adapter URL
# LOBSTER_PI_LLM_ADAPTER_TOKEN=  # Pi-specific adapter token

# --- Workflow ---
# LOBSTER_RUN_STATE_KEY=          # Override run state key
# LOBSTER_MAX_WORKFLOW_DEPTH=10   # Max subworkflow nesting depth
# LOBSTER_WORKFLOW_PATH=          # Search path for workflow files
# LOBSTER_APPROVAL_INPUT_TIMEOUT_MS= # Timeout for interactive approval prompts

# --- Workflow Args (set automatically) ---
# LOBSTER_ARGS_JSON=             # JSON of all workflow args (auto-set)
# LOBSTER_ARG_<NAME>=            # Individual arg values (auto-set)

# --- External Tools ---
# GOG_BIN=gog                    # Path to gog binary for Gmail commands
